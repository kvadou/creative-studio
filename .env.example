# Database (required)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/creative_studio?schema=public"

# Google OAuth (required for authentication)
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# Authentication (required)
JWT_SECRET="any-random-string-for-signing-tokens"

# AI Services (optional — app runs with mock responses when not set)
ANTHROPIC_API_KEY=""    # Enables Claude-powered generation
OPENAI_API_KEY=""       # Enables OpenAI embeddings (legacy, Gemini used by default)
GEMINI_API_KEY=""       # Enables Gemini embeddings + character art

# Server
PORT=3001
NODE_ENV=development

# Retrieval settings
SIMILARITY_THRESHOLD=0.4
MAX_CHUNKS_PER_QUERY=8

# Optional integrations
REPLICATE_API_TOKEN=""       # Flux LoRA illustration generation
ELEVENLABS_API_KEY=""        # Character voice generation
AWS_ACCESS_KEY_ID=""         # S3 asset storage
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME="creative-studio-assets"
S3_REGION="us-east-1"
